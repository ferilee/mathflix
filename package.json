{
  "name": "mathflix-admin",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:billing": "cd mathflix-billing && bun run dev",
    "dev:all": "concurrently \"bun run dev\" \"bun run dev:billing\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "bump:patch": "npm version patch",
    "bump:minor": "npm version minor",
    "version:dump": "echo Current Version: $npm_package_version"
  },
  "dependencies": {
    "@vueup/vue-quill": "^1.2.0",
    "axios": "^1.13.2",
    "katex": "^0.16.27",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vue-tsc": "^3.1.4"
  }
}
